{
	"name": "ispub-sv",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"start": "rm -rf .svelte-kit && vite build && vite preview --port 5173",
		"build": "vite build",
		"preview": "vite preview --port 5173",
		"prepare": "husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json && eslint .",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"precommit": "pnpm format && eslint . --fix",
		"lint-staged": "lint-staged",
		"start:docker": "docker compose up --build",
		"stop:docker": "docker compose down",
		"clean:docker": "docker compose down --rmi all --volumes --remove-orphans"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@lucide/svelte": "^1.17.0",
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.2",
		"clsx": "^2.1.1",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"svelte": "^5.56.2",
		"svelte-check": "^4.6.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vite-plugin-devtools-json": "^1.0.0"
	},
	"dependencies": {
		"mode-watcher": "^1.1.0",
		"zod": "^4.4.3"
	},
	"lint-staged": {
		"*.{js,cjs,mjs,ts,cts,mts,jsx,tsx,svelte}": [
			"prettier --write",
			"eslint --fix"
		],
		"*.{css,scss,sass,less,md,mdx,json,yml,yaml}": [
			"prettier --write"
		]
	},
	"packageManager": "pnpm@11.5.2"
}
